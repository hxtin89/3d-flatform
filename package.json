{
  "name": "sbb-pointcloud-pipeline",
  "version": "1.0.0",
  "description": "Local self-hosted point cloud pipeline: LAZ → PDAL → COPC → 3D Tiles → CesiumJS",
  "scripts": {
    "pipeline:download": "bash pipeline/download.sh",
    "pipeline:inspect": "bash pipeline/inspect.sh",
    "pipeline:prepare": "bash pipeline/prepare.sh",
    "pipeline:chunk": "bash pipeline/chunk.sh",
    "pipeline:copc": "bash pipeline/copc.sh",
    "pipeline:copc:chunks": "bash pipeline/copc-chunks.sh",
    "pipeline:tiles": "bash pipeline/tiles.sh",
    "pipeline:tiles:copc": "bash pipeline/copc-tiles.sh",
    "pipeline:tiles:copc:chunks": "bash pipeline/copc-tiles-chunks.sh",
    "pipeline:area:manifest": "bash pipeline/area-manifest.sh",
    "pipeline:area:one-lod-tree": "bash pipeline/area-one-lod-tree.sh",
    "pipeline:area:overview": "bash pipeline/area-overview.sh",
    "pipeline:area:overview:excluding": "bash pipeline/area-overview-excluding.sh",
    "pipeline:area:overview:p001": "bash pipeline/area-overview-p001.sh",
    "pipeline:area:overview:p001:excluding": "bash pipeline/area-overview-p001-excluding.sh",
    "pipeline:area:explore": "bash pipeline/area-explore.sh",
    "pipeline:area:detail": "bash pipeline/area-detail.sh",
    "pipeline:area:explore:all": "bash pipeline/area-all.sh --mode explore",
    "pipeline:area:detail:all": "bash pipeline/area-all.sh --mode detail",
    "pipeline:serve": "npx sirv-cli local-storage/tilesets --port 8081 --cors --dev",
    "pipeline:all": "bash pipeline/all.sh",
    "viewer:dev": "cd viewer && npm run dev",
    "viewer:install": "cd viewer && npm install"
  },
  "devDependencies": {
    "sirv-cli": "^2.0.2"
  }
}
